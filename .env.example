# ── ZOE: variables de entorno ──
# Todas opcionales: los defaults sirven para la demo local standalone.
# Copia este archivo como .env y ajusta si hace falta. NUNCA subas un .env real.

# Directorio de la memoria/wiki (archivos markdown)
ZOE_MEMORY_DIR=./memory

# Indice SQLite que consulta /search (se genera con examples/build_demo_index.py)
ZOE_DB_PATH=./data/index.sqlite

# Ruta al docker-compose.yml del runtime OpenClaw (OPCIONAL).
# Vacio = modo standalone: sin contenedor, la indexacion la hace el script demo.
ZOE_COMPOSE_FILE=

# Daemon Ollama para los roles LLM del pipeline de ingesta
OLLAMA_URL=http://localhost:11434

# Fuerza el nº de hilos globales de los roles LLM (default: data/modelos.json)
ZOE_HILOS=

# CORS: cerrado por defecto (same-origin). Solo si una UI corre en otro origen,
# lista separada por comas: ZOE_CORS_ORIGINS=https://ui.ejemplo.com
ZOE_CORS_ORIGINS=

# Hosts aceptados ademas de localhost:8900 y 127.0.0.1:8900 (guard anti
# DNS-rebinding). P. ej. el hostname de Tailscale:
# ZOE_ALLOWED_HOSTS=mi-maquina.tailXXXX.ts.net:8900
ZOE_ALLOWED_HOSTS=

# Worker de la bandeja de ingesta. 0 = no arranca al importar app (lo usan los
# tests para no procesar el data/inbox/ real). Default: 1 (activo).
ZOE_WORKER=1

# Nota: el token de la API se genera solo en data/upload_token.txt al primer
# arranque (no es una variable de entorno y nunca debe subirse). Se presenta
# por header (Authorization: Bearer <token> o X-Token) o cookie; el query
# string solo se acepta en /subir y /modelos como bootstrap y se canjea por
# cookie con URL limpia.
